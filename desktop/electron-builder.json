{
  "appId": "com.worldengine.app",
  "productName": "WorldEngine",
  "directories": {
    "output": "dist"
  },
  "electronLanguages": ["en", "zh_CN", "zh_TW"],
  "files": [
    "src/**/*",
    "assets/**/*"
  ],
  "extraResources": [
    {
      "from": "../backend",
      "to": "backend",
      "filter": [
        "**/*",
        "!tests",
        "!node_modules"
      ]
    },
    {
      "from": "../backend/node_modules",
      "to": "backend/node_modules",
      "filter": [
        "**/*",
        "!.cache",
        "!.package-lock.json"
      ]
    },
    {
      "from": "../frontend/dist",
      "to": "frontend/dist",
      "filter": ["**/*"]
    },
    {
      "from": "../assistant",
      "to": "assistant",
      "filter": [
        "**/*",
        "!tests",
        "!node_modules"
      ]
    },
    {
      "from": "../assistant/node_modules",
      "to": "assistant/node_modules",
      "filter": [
        "**/*",
        "!.cache",
        "!.package-lock.json"
      ]
    },
    {
      "from": "../shared",
      "to": "shared",
      "filter": ["**/*"]
    }
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      }
    ],
    "artifactName": "${productName}-${version}-mac-${arch}.${ext}",
    "icon": "assets/icon.icns",
    "extraResources": [
      {
        "from": "node-runtime/darwin-${arch}",
        "to": "node/darwin-${arch}"
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "artifactName": "${productName}-${version}-win-${arch}.${ext}",
    "icon": "assets/icon.ico",
    "extraResources": [
      {
        "from": "node-runtime/win32-${arch}",
        "to": "node/win32-${arch}"
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  }
}

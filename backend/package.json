{
  "name": "worldengine-backend",
  "version": "0.0.3",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "predev": "lsof -ti tcp:3000 | xargs kill -9 2>/dev/null || true",
    "dev": "LOG_LEVEL=debug node --watch server.js",
    "start": "node server.js",
    "db:reset": "node db/reset.js",
    "test": "node --test --test-isolation=process \"tests/**/*.test.js\"",
    "test:coverage": "node --test --test-isolation=process --experimental-test-coverage \"tests/**/*.test.js\""
  },
  "dependencies": {
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "undici": "^8.1.0"
  }
}
